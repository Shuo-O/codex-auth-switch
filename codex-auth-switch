#!/usr/bin/env python3
"""Switch Codex auth.json profiles without logging in repeatedly."""

from __future__ import annotations

import argparse
import base64
import binascii
from dataclasses import dataclass
import datetime as dt
import json
import os
import re
import shutil
import sys
import tempfile
from pathlib import Path


DEFAULT_AUTH = Path("~/.codex/auth.json").expanduser()
DEFAULT_PROFILES = Path("~/.codex/auth-profiles").expanduser()
PROFILE_RE = re.compile(r"^[A-Za-z0-9._-]+$")


class CliError(Exception):
    pass


@dataclass(frozen=True)
class SwitchResult:
    backup_path: Path | None = None
    synced_profile: str | None = None


def die(message: str) -> None:
    raise CliError(message)


def profile_path(name: str, profiles_dir: Path) -> Path:
    if not PROFILE_RE.fullmatch(name):
        die("profile 名只能包含字母、数字、点号、下划线和短横线")
    return profiles_dir / f"{name}.json"


def read_json_file(path: Path) -> object:
    if not path.exists():
        die(f"文件不存在: {path}")
    if not path.is_file():
        die(f"不是普通文件: {path}")
    try:
        with path.open("r", encoding="utf-8") as f:
            return json.load(f)
    except json.JSONDecodeError as exc:
        die(f"JSON 无法解析: {path}: {exc}")


def ensure_json_file(path: Path) -> None:
    read_json_file(path)


def decode_jwt_payload(token: str) -> dict[str, object]:
    parts = token.split(".")
    if len(parts) < 2:
        return {}
    payload = parts[1] + "=" * (-len(parts[1]) % 4)
    try:
        decoded = base64.urlsafe_b64decode(payload.encode("ascii"))
        data = json.loads(decoded)
    except (binascii.Error, ValueError, UnicodeDecodeError, json.JSONDecodeError):
        return {}
    return data if isinstance(data, dict) else {}


def email_from_payload(payload: dict[str, object]) -> str | None:
    email = payload.get("email")
    if isinstance(email, str) and email:
        return email

    profile = payload.get("https://api.openai.com/profile")
    if isinstance(profile, dict):
        profile_email = profile.get("email")
        if isinstance(profile_email, str) and profile_email:
            return profile_email
    return None


def email_from_auth_data(data: object) -> str | None:
    if not isinstance(data, dict):
        return None

    token_sources = []
    tokens = data.get("tokens")
    if isinstance(tokens, dict):
        token_sources.extend(tokens.get(key) for key in ("id_token", "access_token"))
    token_sources.extend(data.get(key) for key in ("id_token", "access_token"))

    for token in token_sources:
        if not isinstance(token, str):
            continue
        email = email_from_payload(decode_jwt_payload(token))
        if email:
            return email
    return None


def jwt_payloads_from_auth_data(data: object) -> list[dict[str, object]]:
    if not isinstance(data, dict):
        return []

    token_sources = []
    tokens = data.get("tokens")
    if isinstance(tokens, dict):
        token_sources.extend(tokens.get(key) for key in ("access_token", "id_token"))
    token_sources.extend(data.get(key) for key in ("access_token", "id_token"))

    payloads = []
    for token in token_sources:
        if isinstance(token, str):
            payload = decode_jwt_payload(token)
            if payload:
                payloads.append(payload)
    return payloads


def identity_from_auth_data(data: object) -> str | None:
    if not isinstance(data, dict):
        return None

    tokens = data.get("tokens")
    if isinstance(tokens, dict):
        account_id = tokens.get("account_id")
        if isinstance(account_id, str) and account_id:
            return f"account:{account_id}"

    for payload in jwt_payloads_from_auth_data(data):
        sub = payload.get("sub")
        if isinstance(sub, str) and sub:
            return f"sub:{sub}"

    email = email_from_auth_data(data)
    return f"email:{email}" if email else None


def identity_from_auth_file(path: Path) -> str | None:
    return identity_from_auth_data(read_json_file(path))


def access_token_exp_from_auth_data(data: object) -> int | None:
    if not isinstance(data, dict):
        return None

    token_sources = []
    tokens = data.get("tokens")
    if isinstance(tokens, dict):
        token_sources.append(tokens.get("access_token"))
    token_sources.append(data.get("access_token"))

    for token in token_sources:
        if not isinstance(token, str):
            continue
        exp = decode_jwt_payload(token).get("exp")
        if isinstance(exp, int):
            return exp
        if isinstance(exp, str) and exp.isdigit():
            return int(exp)
    return None


def parse_timestamp(value: object) -> int | None:
    if not isinstance(value, str) or not value:
        return None
    try:
        parsed = dt.datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    return int(parsed.timestamp())


def auth_freshness_score(data: object) -> tuple[int, int]:
    if not isinstance(data, dict):
        return (0, 0)
    last_refresh = parse_timestamp(data.get("last_refresh")) or 0
    access_exp = access_token_exp_from_auth_data(data) or 0
    return (last_refresh, access_exp)


def email_from_auth_file(path: Path) -> str | None:
    return email_from_auth_data(read_json_file(path))


def safe_email_from_auth_file(path: Path) -> str:
    try:
        return email_from_auth_file(path) or "-"
    except CliError:
        return "-"


def token_status_from_auth_file(path: Path) -> str:
    try:
        exp = access_token_exp_from_auth_data(read_json_file(path))
    except CliError:
        return "token ?"
    if exp is None:
        return "token ?"

    now = int(dt.datetime.now(dt.timezone.utc).timestamp())
    remaining = exp - now
    if remaining <= 0:
        return "access expired"
    if remaining < 3600:
        minutes = max(1, remaining // 60)
        return f"access {minutes}m"
    if remaining < 86400:
        hours = max(1, remaining // 3600)
        return f"access {hours}h"
    days = max(1, remaining // 86400)
    return f"access {days}d"


def chmod_owner_only(path: Path) -> None:
    try:
        path.chmod(0o600)
    except PermissionError:
        pass


def copy_atomic(src: Path, dst: Path) -> None:
    dst.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        "wb", delete=False, dir=str(dst.parent), prefix=f".{dst.name}.", suffix=".tmp"
    ) as tmp:
        tmp_path = Path(tmp.name)
        with src.open("rb") as f:
            shutil.copyfileobj(f, tmp)
    shutil.copystat(src, tmp_path, follow_symlinks=True)
    chmod_owner_only(tmp_path)
    os.replace(tmp_path, dst)


def backup_current(auth_path: Path, profiles_dir: Path) -> Path | None:
    if not auth_path.exists():
        return None
    timestamp = dt.datetime.now().strftime("%Y%m%d-%H%M%S-%f")
    backup_dir = profiles_dir / ".backups"
    backup_path = backup_dir / f"auth-{timestamp}.json"
    copy_atomic(auth_path, backup_path)
    return backup_path


def list_profile_names(profiles_dir: Path) -> list[str]:
    if not profiles_dir.exists():
        return []
    return sorted(path.stem for path in profiles_dir.glob("*.json") if path.is_file())


def matching_profiles(auth_path: Path, profiles_dir: Path) -> list[str]:
    ensure_json_file(auth_path)
    current = auth_path.read_bytes()
    matches = []
    if profiles_dir.exists():
        for path in sorted(profiles_dir.glob("*.json")):
            if path.is_file() and path.read_bytes() == current:
                matches.append(path.stem)
    return matches


def find_profile_for_auth(auth_path: Path, profiles_dir: Path) -> str | None:
    if not auth_path.exists() or not profiles_dir.exists():
        return None

    try:
        exact_matches = matching_profiles(auth_path, profiles_dir)
    except CliError:
        return None
    if len(exact_matches) == 1:
        return exact_matches[0]

    try:
        current_identity = identity_from_auth_file(auth_path)
    except CliError:
        return None
    if not current_identity:
        return None

    identity_matches = []
    for name in list_profile_names(profiles_dir):
        try:
            profile_identity = identity_from_auth_file(profile_path(name, profiles_dir))
        except CliError:
            continue
        if profile_identity == current_identity:
            identity_matches.append(name)

    return identity_matches[0] if len(identity_matches) == 1 else None


def sync_current_profile(auth_path: Path, profiles_dir: Path) -> str | None:
    current_profile = find_profile_for_auth(auth_path, profiles_dir)
    if not current_profile:
        return None

    target = profile_path(current_profile, profiles_dir)
    current_data = read_json_file(auth_path)
    target_data = read_json_file(target)
    if auth_freshness_score(current_data) < auth_freshness_score(target_data):
        return None

    if auth_path.read_bytes() != target.read_bytes():
        copy_atomic(auth_path, target)
        return current_profile
    return None


def switch_profile(
    name: str, auth_path: Path, profiles_dir: Path, no_backup: bool = False
) -> SwitchResult:
    source = profile_path(name, profiles_dir)
    ensure_json_file(source)
    synced_profile = sync_current_profile(auth_path, profiles_dir)
    backup_path = None if no_backup else backup_current(auth_path, profiles_dir)
    copy_atomic(source, auth_path)
    return SwitchResult(backup_path=backup_path, synced_profile=synced_profile)


def cmd_save(args: argparse.Namespace) -> None:
    auth_path = args.auth.expanduser()
    profiles_dir = args.profiles_dir.expanduser()
    ensure_json_file(auth_path)

    target = profile_path(args.name, profiles_dir)
    if target.exists() and not args.force:
        die(f"profile 已存在: {args.name}，如需覆盖请加 --force")

    copy_atomic(auth_path, target)
    print(f"已保存当前 Codex 登录态为 profile: {args.name}")
    print(f"位置: {target}")


def cmd_use(args: argparse.Namespace) -> None:
    auth_path = args.auth.expanduser()
    profiles_dir = args.profiles_dir.expanduser()
    result = switch_profile(args.name, auth_path, profiles_dir, args.no_backup)
    print(f"已切换到 profile: {args.name}")
    print(f"写入: {auth_path}")
    if result.synced_profile:
        print(f"已同步当前登录态到 profile: {result.synced_profile}")
    if result.backup_path:
        print(f"已备份切换前 auth: {result.backup_path}")


def cmd_list(args: argparse.Namespace) -> None:
    profiles_dir = args.profiles_dir.expanduser()
    profiles = list_profile_names(profiles_dir)
    if not profiles:
        print("暂无 profiles")
        return
    for name in profiles:
        print(name)


def cmd_remove(args: argparse.Namespace) -> None:
    profiles_dir = args.profiles_dir.expanduser()
    target = profile_path(args.name, profiles_dir)
    if not target.exists():
        die(f"profile 不存在: {args.name}")
    if not args.force:
        die(f"删除 profile: {args.name} 需要加 --force")
    target.unlink()
    print(f"已删除 profile: {args.name}")


def cmd_current(args: argparse.Namespace) -> None:
    auth_path = args.auth.expanduser()
    profiles_dir = args.profiles_dir.expanduser()
    matches = matching_profiles(auth_path, profiles_dir)

    if matches:
        print("当前 auth 匹配 profile:")
        for name in matches:
            print(name)
    else:
        print("当前 auth 未匹配任何已保存 profile")


def cmd_menu(args: argparse.Namespace) -> None:
    auth_path = args.auth.expanduser()
    profiles_dir = args.profiles_dir.expanduser()
    profiles = list_profile_names(profiles_dir)
    if not profiles:
        die("暂无 profiles。先登录一个账号，然后运行: codex-auth-switch add <name>")

    matches = []
    if auth_path.exists():
        sync_current_profile(auth_path, profiles_dir)
        current_profile = find_profile_for_auth(auth_path, profiles_dir)
        if current_profile:
            matches = [current_profile]

    print("Codex profiles:")
    name_width = max(len(name) for name in profiles)
    rows = []
    for name in profiles:
        path = profile_path(name, profiles_dir)
        rows.append(
            (name, safe_email_from_auth_file(path), token_status_from_auth_file(path))
        )
    email_width = max(len(email) for _, email, _ in rows)
    for index, (name, email, status) in enumerate(rows, start=1):
        marker = "*" if name in matches else " "
        print(
            f"{index:>2}. {marker} {name:<{name_width}}  "
            f"{email:<{email_width}}  {status}"
        )
    print()
    choice = input("输入序号切换，或直接回车取消: ").strip()
    if not choice:
        print("已取消")
        return
    if not choice.isdigit():
        die("请输入列表里的数字序号")
    index = int(choice)
    if index < 1 or index > len(profiles):
        die("序号超出范围")

    name = profiles[index - 1]
    result = switch_profile(name, auth_path, profiles_dir, args.no_backup)
    print(f"已切换到 profile: {name}")
    if result.synced_profile:
        print(f"已同步当前登录态到 profile: {result.synced_profile}")
    if result.backup_path:
        print(f"已备份切换前 auth: {result.backup_path}")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="codex-auth-switch",
        description="通过替换 Codex auth.json 快速切换多个账号。",
    )
    parser.add_argument(
        "--auth",
        type=Path,
        default=DEFAULT_AUTH,
        help=f"Codex auth.json 路径，默认: {DEFAULT_AUTH}",
    )
    parser.add_argument(
        "--profiles-dir",
        type=Path,
        default=DEFAULT_PROFILES,
        help=f"profile 存放目录，默认: {DEFAULT_PROFILES}",
    )

    parser.set_defaults(func=cmd_menu)
    parser.add_argument(
        "--no-backup",
        action="store_true",
        help="交互切换前不备份当前 auth.json",
    )

    subparsers = parser.add_subparsers(dest="command")

    save = subparsers.add_parser(
        "save", aliases=["add"], help="把当前 auth.json 保存为一个 profile"
    )
    save.add_argument("name", help="profile 名称，例如 work 或 personal")
    save.add_argument("-f", "--force", action="store_true", help="覆盖同名 profile")
    save.set_defaults(func=cmd_save)

    use = subparsers.add_parser(
        "use", aliases=["switch"], help="切换到指定 profile"
    )
    use.add_argument("name", help="profile 名称")
    use.add_argument(
        "--no-backup",
        action="store_true",
        help="切换前不备份当前 auth.json",
    )
    use.set_defaults(func=cmd_use)

    list_profiles = subparsers.add_parser(
        "list", aliases=["ls"], help="列出已保存 profiles"
    )
    list_profiles.set_defaults(func=cmd_list)

    current = subparsers.add_parser(
        "current", aliases=["whoami"], help="显示当前 auth 匹配哪个 profile"
    )
    current.set_defaults(func=cmd_current)

    remove = subparsers.add_parser(
        "remove", aliases=["rm"], help="删除一个 profile"
    )
    remove.add_argument("name", help="profile 名称")
    remove.add_argument("-f", "--force", action="store_true", help="确认删除")
    remove.set_defaults(func=cmd_remove)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        args.func(args)
    except CliError as exc:
        print(f"错误: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
